# mdeai.co — public env vars baked into the frontend bundle at build time.
# Copy this file to `.env` for local dev. Real values live in Vercel's
# environment variables dashboard for production builds.
#
# IMPORTANT: only `VITE_*` prefixed vars are exposed to client code.
# Anything else gets stripped by Vite at build time. Never put server
# secrets here — those live in Supabase Edge Function secrets or
# Vercel server-only env.

# ─── Supabase (anon key — safe to ship) ───
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=

# ─── Google Maps JavaScript API key ───
# Restrict in Cloud Console: HTTP referrers + API restriction = "Maps JavaScript API only".
VITE_GOOGLE_MAPS_API_KEY=

# ─── Sentry browser SDK ───
# Public DSN — Sentry's design says this is safe in client bundles
# (it authenticates events to a project but does not grant API access).
# If empty, Sentry init is a no-op (dev-friendly default).
VITE_SENTRY_DSN=

# ─── PostHog product analytics ───
# Public project token (write-only) — safe in client bundles per PostHog's docs.
# If empty, PostHog init + every trackEvent() call is a silent no-op.
VITE_POSTHOG_KEY=
# Optional override — defaults to https://us.i.posthog.com when unset.
VITE_POSTHOG_HOST=
