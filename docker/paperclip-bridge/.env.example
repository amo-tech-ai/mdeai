# Bridge service config — copy to .env and fill from Infisical (NEVER commit real values)
PORT=3200
NODE_ENV=production
LOG_LEVEL=info

# 32+ hex chars; sourced from Infisical as BRIDGE_SECRET
BRIDGE_SECRET=

# Internal Docker DNS (resolves once attach-networks.sh joins all 4 networks)
OPENCLAW_INTERNAL_URL=http://openclaw:8080
HERMES_INTERNAL_URL=http://hermes-agent:8000
POSTIZ_INTERNAL_URL=http://postiz:3000
PAPERCLIP_INTERNAL_URL=http://paperclip:49038

# Downstream credentials (bridge holds these so callers don't have to)
PAPERCLIP_API_KEY=
POSTIZ_API_KEY=
OPENCLAW_GATEWAY_TOKEN=

# Supabase service role (audit writes only)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Upstream timeout (ms)
UPSTREAM_TIMEOUT_MS=10000
