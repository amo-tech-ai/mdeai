        HermesRuntime["Hermes Agent<br/>────────<br/>Python 3.11.15<br/>CLI: hermes chat -q<br/>Config: ~/.hermes/<br/>637 skills installed<br/>────────<br/>Spawned per heartbeat<br/>via hermes_local adapter"]

        OpenClawServer["OpenClaw Gateway<br/>────────<br/>Self-hosted (Phase 3)<br/>Channel adapters<br/>State machine<br/>────────<br/>Docker / VPS"]
