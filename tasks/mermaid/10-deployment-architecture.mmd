        SupaStorage["Storage<br/>────────<br/>property-images (public)<br/>contracts (private/RLS)<br/>applications (private/RLS)"]

        SupaRealtime["Realtime<br/>────────<br/>WebSocket subscriptions<br/>Bookings, notifications,<br/>chat messages"]
    end

